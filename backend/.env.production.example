# =============================================================================
# SasVault — Production environment variables template
# =============================================================================
# Copy this file to .env.production and fill in all values before deploying.
# NEVER commit .env.production to version control.
#
# Generate a secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# =============================================================================

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_urlsafe(50))">
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=<VPS_IP_or_domain>

# Comma-separated origins allowed for CORS (must match the frontend URL)
CORS_ALLOWED_ORIGINS=https://<VPS_IP_or_domain>

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DB_NAME=saasvault_prod
DB_USER=saasvault_user
DB_PASSWORD=<strong_password>
DB_HOST=postgres
DB_PORT=5432

# Native PostgreSQL container variables — must match the DB_* values above.
# The postgres Docker image reads these to initialize the database on first run.
# docker-compose.prod.yml passes env_file directly to avoid ${} interpolation
# issues, so these native names must be present here.
POSTGRES_DB=saasvault_prod
POSTGRES_USER=saasvault_user
POSTGRES_PASSWORD=<strong_password>

# ---------------------------------------------------------------------------
# Redis — cache, Celery broker, and result backend (three separate databases)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_DEFAULT_RETRY_DELAY=60
CELERY_TASK_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# MinIO — object storage for document blobs
# NEVER use the default minioadmin/minioadmin credentials in production.
# ---------------------------------------------------------------------------
MINIO_ACCESS_KEY=<strong_access_key>
MINIO_SECRET_KEY=<strong_secret_key>
MINIO_BUCKET_NAME=saasvault-prod
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=False

# Native MinIO container variables — must match MINIO_ACCESS_KEY / MINIO_SECRET_KEY.
# The MinIO Docker image reads these to set the root credentials on first run.
# docker-compose.prod.yml passes env_file directly to avoid ${} interpolation
# issues, so these native names must be present here.
MINIO_ROOT_USER=<strong_access_key>
MINIO_ROOT_PASSWORD=<strong_secret_key>

# ---------------------------------------------------------------------------
# OCR (requires system packages: tesseract-ocr tesseract-ocr-spa poppler-utils)
# These are already installed in the backend Docker image.
# ---------------------------------------------------------------------------
OCR_LANGUAGES=spa+eng
OCR_PDF_DPI=200
ORPHAN_BLOB_GRACE_HOURS=24

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_ACCESS_LIFETIME_MIN=15

# ---------------------------------------------------------------------------
# Sentry — error tracking (optional; leave empty to disable)
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Email via SendGrid (optional; leave SENDGRID_API_KEY empty to disable)
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@sasvault.dev

# ---------------------------------------------------------------------------
# AI analysis via Anthropic Claude (optional; leave empty to disable)
# Endpoint returns 503 when this key is absent.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
AI_MAX_INPUT_CHARS=12000
