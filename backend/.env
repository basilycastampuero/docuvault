# Django
DJANGO_SECRET_KEY=django-insecure-cambiar-esto-en-produccion-usar-python-secrets
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos
DB_NAME=docuvault_db
DB_USER=docuvault_user
DB_PASSWORD=docuvault_pass_local
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (object storage local)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=docuvault-documents
MINIO_USE_SSL=False

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Sentry (dejar vacío en desarrollo)
SENTRY_DSN=
