# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos
DB_NAME=saasvault_db
DB_USER=saasvault_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-key
MINIO_SECRET_KEY=your-minio-secret
MINIO_BUCKET_NAME=saasvault-documents
MINIO_USE_SSL=False

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_DEFAULT_RETRY_DELAY=60
CELERY_TASK_MAX_RETRIES=3
ORPHAN_BLOB_GRACE_HOURS=24    # Grace window (hours) for orphan blob cleanup; blobs newer than this are never deleted

# System dependencies (apt) required for full functionality:
#   sudo apt-get install -y tesseract-ocr tesseract-ocr-spa poppler-utils libmagic1 redis-tools graphviz
#   redis-tools: provides redis-cli for manual Redis inspection and health checks
#   graphviz: required to generate the ERD diagram with `python manage.py graph_models`
#
# OCR (requires apt: tesseract-ocr tesseract-ocr-spa poppler-utils)
OCR_LANGUAGES=spa+eng
OCR_PDF_DPI=200

# AI Analysis (optional — leave empty to disable, endpoint returns 503)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
AI_MAX_INPUT_CHARS=12000

# Observability
SENTRY_DSN=           # Leave empty to disable Sentry
SENTRY_ENVIRONMENT=development

# Email (Fase 5.7 — Notificaciones por email)
# In development, EMAIL_BACKEND is overridden to console in development.py — these
# settings only take effect in production. Leave SENDGRID_API_KEY empty to send nothing.
DEFAULT_FROM_EMAIL=noreply@sasvault.dev
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
SENDGRID_API_KEY=      # SendGrid API key; leave empty to disable outgoing email

# Auth cookies (Fase 6.1 — refresh token en cookie httpOnly + CSRF double-submit)
# AUTH_REFRESH_COOKIE_SECURE is overridden to False in development.py/test.py (no HTTPS locally).
AUTH_REFRESH_COOKIE_ENABLED=True   # feature flag: False = comportamiento legado (refresh en el body)
AUTH_REFRESH_COOKIE_NAME=sv_refresh
AUTH_REFRESH_COOKIE_SAMESITE=Strict
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_CSRF_COOKIE_NAME=sv_csrf
