# API
# DEBE ser relativa (no "http://localhost:8000/api/v1"). El dev server de Vite
# (vite.config.ts -> server.proxy['/api']) reenvía /api al backend en localhost:8000
# para que el navegador vea todo como same-origin. Esto es un prerrequisito duro
# desde Fase 6.1: la cookie httpOnly del refresh token usa SameSite=Strict, y con
# una URL absoluta la request sería cross-origin y el navegador nunca adjuntaría
# la cookie, rompiendo el refresh silencioso de sesión.
VITE_API_BASE_URL=/api/v1
